{
  "name": "omeagle",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "postbuild": "react-snap || true",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "canvas-confetti": "^1.9.4",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "react-snap": "^1.23.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "include": [
      "/",
      "/about",
      "/privacy",
      "/terms",
      "/contact",
      "/blog",
      "/blog/omeagle-free-random-video-chat",
      "/blog/best-omegle-alternatives",
      "/blog/safe-video-chat-guide",
      "/blog/ometv-alternative",
      "/blog/no-signup-video-chat",
      "/blog/text-chat-with-strangers",
      "/safety"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-gpu"
    ],
    "minifyHtml": { "collapseWhitespace": true, "removeComments": false },
    "inlineCss": false,
    "saveAs": "html"
  }
}
